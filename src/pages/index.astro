---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Comboni Front-End Dev Summer Camp 2026">
  <!-- Premium Hero Section with Ambient Dark Blurry Background Image -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden bg-[#030712] py-24">
    <!-- Background Image with deep dark-blue overlay and blurry filter for absolute text contrast -->
    <div class="absolute inset-0 z-0 overflow-hidden">
      <img 
        src="/images/winter4.jpg" 
        alt="Comboni Dev Workspace Background" 
        class="w-full h-full object-cover filter brightness-[0.7] contrast-[1.1] blur-sm scale-105"
      />
      <!-- Radial gradient overlay - lightened to let the background image shine through cleanly -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#030712]/40 via-[#091022]/60 to-[#030712]"></div>
      <!-- Subtle grid line layout overlay to give a tech atmosphere -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-25 [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>
    </div>

    <!-- Content Wrapper -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center space-y-8">
      <!-- High School Elite Track Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs sm:text-sm font-bold bg-blue-950/80 text-blue-400 border border-blue-900/50 backdrop-blur-md mx-auto">
        ⚡ Elite High School Coding Track
      </div>

      <!-- HUGE Headline (Comboni Summer Camp 2026) -->
      <div class="space-y-4">
        <h1 class="text-5xl sm:text-7xl lg:text-8xl font-black text-white tracking-tight leading-none uppercase">
          Comboni <br class="sm:hidden" />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-cyan-300 to-white">
            Summer Camp
          </span> 
          <span class="text-white">2026</span>
        </h1>
        <p class="text-lg sm:text-2xl text-slate-300 max-w-2xl mx-auto font-medium tracking-wide">
          Master the Front-End, code modern responsive layouts, and deploy dynamic web projects this summer.
        </p>
      </div>

      <!-- Call to Actions -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center pt-4">
        <a 
          href="/book" 
          class="w-full sm:w-auto bg-gradient-to-r from-blue-600 to-cyan-500 hover:from-blue-500 hover:to-cyan-400 active:scale-95 text-white font-extrabold text-center px-10 py-5 rounded-2xl shadow-xl shadow-blue-500/20 transition-all text-base sm:text-lg"
        >
          Book Your Dev Seat
        </a>
        <a 
          href="#curriculum" 
          class="w-full sm:w-auto bg-slate-900/80 hover:bg-slate-800/80 active:scale-95 text-slate-300 hover:text-white font-bold text-center px-10 py-5 rounded-2xl border border-slate-800 backdrop-blur-sm transition-all text-base sm:text-lg"
        >
          Explore What We Build
        </a>
      </div>
    </div>
  </section>

  <!-- Tech Core Curriculum Focus Section -->
  <section id="curriculum" class="py-20 bg-[#02050e] border-y border-slate-900 relative">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">The 2026 Tech Stack</h2>
        <p class="text-slate-400 mt-3">High schoolers skip boring slides. You will code on real developer sandboxes and learn the same tools used at Netflix, Spotify, and Stripe.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Tech focus 1: HTML -->
        <div class="bg-[#091122]/60 p-8 rounded-2xl border border-slate-800/80 hover:border-blue-500/30 hover:bg-[#0d1830] transition-all group">
          <div class="w-12 h-12 bg-blue-950 text-blue-400 rounded-xl flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform">🌐</div>
          <h3 class="text-xl font-bold text-white mb-2">HTML</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Master semantic document structures, clean formatting hierarchy, search engine optimizations (SEO), and layout framing for all modern web browsers.</p>
        </div>

        <!-- Tech focus 2: CSS & JS -->
        <div class="bg-[#091122]/60 p-8 rounded-2xl border border-slate-800/80 hover:border-blue-500/30 hover:bg-[#0d1830] transition-all group">
          <div class="w-12 h-12 bg-cyan-950 text-cyan-400 rounded-xl flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform">⚙️</div>
          <h3 class="text-xl font-bold text-white mb-2">CSS & JS</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Design beautiful layouts with modern Flexbox and Grid. Then, program dynamic site behaviors, tap gestures, dark modes, and direct API actions using JavaScript.</p>
        </div>

        <!-- Tech focus 3: CSS Frameworks -->
        <div class="bg-[#091122]/60 p-8 rounded-2xl border border-slate-800/80 hover:border-blue-500/30 hover:bg-[#0d1830] transition-all group">
          <div class="w-12 h-12 bg-violet-950 text-violet-400 rounded-xl flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform">⚡</div>
          <h3 class="text-xl font-bold text-white mb-2">CSS Frameworks</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Build premium dashboards and responsive layouts at lightning speed using utility-first frameworks like Tailwind CSS, and handle complex design tokens.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Previous Project & Work Gallery -->
  <section id="gallery" class="py-20 bg-[#030712]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">Student Project Showcase</h2>
        <p class="text-slate-400 mt-3">Interactive, fully-responsive pages built and shipped by high school developers in under 3 weeks.</p>
      </div>
      
      <!-- Photo grid using premium placeholders ready for user images -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Student Project 1 -->
        <div class="bg-[#091122]/60 p-3 rounded-2xl border border-slate-800/80 group">
          <div class="overflow-hidden rounded-xl aspect-[4/3] mb-4 bg-slate-900">
            <img 
              src="/images/winter23.jpg" 
              alt="Interactive UI Screen" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 filter brightness-90"
            />
          </div>
          <p class="text-sm font-bold text-white">Interactive Gaming Dashboard</p>
          <p class="text-xs text-slate-500 mt-1">Built using Tailwind CSS & CSS Variables</p>
        </div>

        <!-- Student Project 2 -->
        <div class="bg-[#091122]/60 p-3 rounded-2xl border border-slate-800/80 group">
          <div class="overflow-hidden rounded-xl aspect-[4/3] mb-4 bg-slate-900">
            <img 
              src="/images/winter6.jpg" 
              alt="Clean web browser portfolio mockup" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 filter brightness-90"
            />
          </div>
          <p class="text-sm font-bold text-white">Developer Portfolio Hub</p>
          <p class="text-xs text-slate-500 mt-1">Built with semantic CSS Grid Systems</p>
        </div>

        <!-- Student Project 3 -->
        <div class="bg-[#091122]/60 p-3 rounded-2xl border border-slate-800/80 group">
          <div class="overflow-hidden rounded-xl aspect-[4/3] mb-4 bg-slate-900">
            <img 
              src="/images/winter5.jpg" 
              alt="Clean web IDE editor showing layout classes" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 filter brightness-90"
            />
          </div>
          <p class="text-sm font-bold text-white">Interactive Coding Playground</p>
          <p class="text-xs text-slate-500 mt-1">Compiled in Astro with full responsiveness</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Booking Banner -->
  <section class="py-20 bg-gradient-to-t from-[#010409] to-[#030712] border-t border-slate-900">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">Space is Strictly Limited to a few Developers</h2>
      <p class="text-slate-400 mb-8 max-w-xl mx-auto text-sm sm:text-base leading-relaxed">
        Due to individual developer sandbox environment setup limits, registration is competitive. Secure your online booking code now, snapshot your confirmation ticket, and fulfill payment at the high school office.
      </p>
      <a 
        href="/book" 
        class="inline-block bg-gradient-to-r from-blue-600 to-cyan-500 hover:from-blue-500 hover:to-cyan-400 active:scale-95 text-white font-extrabold px-10 py-5 rounded-xl shadow-lg shadow-blue-500/20 transition-all text-base sm:text-lg"
      >
        Lock In Your Registration Ticket
      </a>
    </div>
  </section>
  <!-- Lead Instructor Section -->
<section id="instructor" class="py-24 bg-gradient-to-b from-transparent to-[#050a16]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="bg-[#091122] rounded-3xl border border-slate-800 p-8 md:p-12 shadow-2xl">
      <div class="flex flex-col md:flex-row items-center gap-10">
        
        <!-- Updated Huge Image Space -->
        <div class="w-full md:w-1/3 aspect-square bg-slate-800 rounded-2xl border-4 border-slate-700 overflow-hidden shadow-inner flex items-center justify-center">
           <img 
             src="/images/winter7.jpg" 
             alt="Lead Instructor Profile" 
             class="w-full h-full object-cover"
             onerror="this.parentElement.innerHTML='<span class=\'text-slate-600 text-sm font-bold tracking-widest uppercase italic\'>Add your photo</span>'"
           />
        </div>

        <!-- Instructor Details -->
        <div class="flex-1 space-y-6">
          <div>
            <h2 class="text-3xl font-black text-white mb-2">Lead Instructor</h2>
            <p class="text-cyan-400 font-bold text-lg">Senior Web Developer</p>
          </div>
          
          <p class="text-slate-400 leading-relaxed text-lg">
            I specialize in crafting high-performance, responsive web experiences. This summer, I am bringing my decade of industry expertise to our camp to help you master modern front-end frameworks and professional deployment workflows.
          </p>

          <a 
            href="https://my-portfolio-two-wine-86.vercel.app/" 
            target="_blank"
            class="inline-block bg-white hover:bg-slate-200 text-slate-900 font-black px-8 py-4 rounded-xl transition-all shadow-xl hover:shadow-cyan-500/20"
          >
            View My Portfolio →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
</Layout>