---
import '../styles/global.css';

interface Props {
  title: string;
  isAdmin?: boolean;
}

const { title, isAdmin = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Sleek High School Summer Camp Booking Portal" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <title>{title} | High School Camp</title>
  </head>
  <body class="bg-[#030712] text-slate-100 font-['Plus_Jakarta_Sans',sans-serif] min-h-screen flex flex-col selection:bg-blue-500 selection:text-white">
    <!-- Main Header -->
    <header class="bg-[#030712]/80 backdrop-blur-md border-b border-slate-800 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
          <!-- Logo Section -->
          <div class="flex items-center space-x-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-blue-600 to-cyan-400 flex items-center justify-center font-black text-white text-xl shadow-lg shadow-blue-500/20">
              ⚡
            </div>
            <a href="/" class="text-xl font-extrabold tracking-tight text-white sm:text-2xl hover:opacity-90 transition-opacity">
              Camp<span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300">Aura</span>
            </a>
          </div>

          <nav class="flex items-center space-x-4 sm:space-x-6">
            {!isAdmin ? (
              <>
                <a href="/" class="text-sm font-semibold text-slate-300 hover:text-white transition-colors">
                  Overview
                </a>
                <a 
                  href="/book" 
                  class="bg-blue-600 hover:bg-blue-500 text-white text-xs sm:text-sm px-5 py-2.5 rounded-xl font-bold transition-all hover:shadow-lg hover:shadow-blue-500/30 active:scale-95"
                >
                  Book Space
                </a>
                <a href="/admin/login" class="text-xs font-semibold text-slate-400 hover:text-slate-200 border border-slate-800 hover:border-slate-700 rounded-xl px-3 py-2 transition-all">
                  Office Access
                </a>
              </>
            ) : (
              <>
                <a href="/admin/dashboard" class="text-sm font-bold text-white hover:text-blue-300">
                  Dashboard
                </a>
                <a href="/" class="text-xs text-slate-400 hover:text-slate-200">
                  Exit Portal
                </a>
              </>
            )}
          </nav>
        </div>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer section matching deep blue styling -->
    <footer class="bg-[#010409] text-slate-500 py-12 border-t border-slate-900 mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center sm:flex sm:justify-between sm:items-center">
        <p class="text-sm">&copy; {new Date().getFullYear()} CampAura. Built for high school innovators.</p>
        <p class="text-xs mt-3 sm:mt-0 text-slate-600">Mobile-optimized visual confirmation gateway.</p>
      </div>
    </footer>
  </body>
</html>