---
import '../styles/global.css';

interface Props {
  title: string;
  isAdmin?: boolean;
}

const { title, isAdmin = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Sleek High School Summer Camp Booking Portal" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <title>{title} | High School Camp</title>
  </head>
  <body class="bg-[#030712] text-slate-100 font-['Plus_Jakarta_Sans',sans-serif] min-h-screen flex flex-col selection:bg-blue-500 selection:text-white">
    
    <!-- Header -->
    <header class="bg-[#030712]/80 backdrop-blur-md border-b border-slate-800 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex justify-between items-center">
        <!-- Logo -->
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-blue-600 to-cyan-400 flex items-center justify-center font-black text-white text-xl">⚡</div>
          <a href="/" class="text-xl font-extrabold tracking-tight text-white hover:opacity-90">
            Camp<span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300">Aura</span>
          </a>
        </div>

        <!-- Desktop Nav -->
        <nav class="hidden sm:flex items-center space-x-6">
          {isAdmin ? (
            <>
              <a href="/admin/dashboard" class="text-sm font-bold text-white hover:text-blue-300">Dashboard</a>
              <a href="/" class="text-xs text-slate-400 hover:text-slate-200">Exit</a>
            </>
          ) : (
            <>
              <a href="/" class="text-sm font-semibold text-slate-300 hover:text-white">Overview</a>
              <a href="/admin/login" class="text-xs font-semibold text-slate-400 hover:text-slate-200">Office</a>
            </>
          )}
        </nav>

        <!-- Right Side: Always Visible -->
        <div class="flex items-center space-x-3">
          {!isAdmin && (
             <a href="/book" class="bg-blue-600 hover:bg-blue-500 text-white text-sm px-5 py-2.5 rounded-xl font-bold transition-all">Book Space</a>
          )}
          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="sm:hidden p-2 text-white hover:bg-slate-800 rounded-lg">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile Sidebar Drawer -->
    <div id="mobile-sidebar" class="fixed inset-0 z-[60] bg-[#030712] transform -translate-x-full transition-transform duration-300 sm:hidden">
      <div class="p-6 flex flex-col h-full">
        <button id="close-sidebar" class="self-end p-2 text-white"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        <nav class="mt-10 flex flex-col space-y-6 text-2xl font-bold">
          {isAdmin ? (
            <>
              <a href="/admin/dashboard" class="hover:text-blue-400">Dashboard</a>
              <a href="/" class="hover:text-slate-400">Exit Portal</a>
            </>
          ) : (
            <>
              <a href="/" class="hover:text-blue-400">Overview</a>
              <a href="/admin/login" class="hover:text-slate-400">Office Access</a>
            </>
          )}
        </nav>
      </div>
    </div>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="bg-[#010409] text-slate-500 py-12 border-t border-slate-900 mt-auto text-center text-sm">
      &copy; {new Date().getFullYear()} CampAura.
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const close = document.getElementById('close-sidebar');
      const sidebar = document.getElementById('mobile-sidebar');

      btn?.addEventListener('click', () => sidebar?.classList.remove('-translate-x-full'));
      close?.addEventListener('click', () => sidebar?.classList.add('-translate-x-full'));
    </script>
  </body>
</html>